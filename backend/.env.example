# ─── Server ───────────────────────────────
PORT=3001
NODE_ENV=development

# ─── CORS ─────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── Rate Limiting ────────────────────────
# Max socket events per second per connection
RATE_LIMIT_EVENTS_PER_SECOND=10

# ─── Session ──────────────────────────────
# Inactivity timeout before auto-ending a chat (ms)
SESSION_TIMEOUT_MS=300000

# ─── Message ──────────────────────────────
# Max encrypted message payload size (bytes)
MAX_MESSAGE_BYTES=4096
